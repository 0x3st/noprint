From 5e9bc7f99f5f8d2120f0d0344ca2a6f8de889001 Mon Sep 17 00:00:00 2001
From: anti-det <anti-det@local>
Date: Mon, 2 Mar 2026 12:00:00 +0800
Subject: [PATCH] chrome: add --antidetect-config switch entrypoint

Register a dedicated command line switch in Chromium so launcher-side
runtime JSON can be passed via:

  --antidetect-config=/abs/path/to/runtime_config.json

This is the minimum base patch for later network/render hooks.
---
 chrome/common/chrome_switches.cc | 4 ++++
 chrome/common/chrome_switches.h  | 3 +++
 2 files changed, 7 insertions(+)

diff --git a/chrome/common/chrome_switches.cc b/chrome/common/chrome_switches.cc
index 6523f2ab8f0b..ee1242d15567 100644
--- a/chrome/common/chrome_switches.cc
+++ b/chrome/common/chrome_switches.cc
@@ -120,6 +120,10 @@ const char kAllowNoSandboxJob[] = "allow-no-sandbox-job";
 // Allows third-party content included on a page to prompt for a HTTP basic auth
 // username/password pair.
 const char kAllowCrossOriginAuthPrompt[] = "allow-cross-origin-auth-prompt";
+
+// Absolute path to anti-detect runtime JSON config generated by launcher.
+// Example: --antidetect-config=/path/to/runtime_config.json
+const char kAntidetectConfig[] = "antidetect-config";
 #endif  // BUILDFLAG(IS_WIN)

 #if BUILDFLAG(IS_CHROMEOS)
diff --git a/chrome/common/chrome_switches.h b/chrome/common/chrome_switches.h
index 68cc4965f5ab..7fd8b79def63 100644
--- a/chrome/common/chrome_switches.h
+++ b/chrome/common/chrome_switches.h
@@ -42,6 +42,7 @@ extern const char kAllowCrossOriginAuthPrompt[];
 #if BUILDFLAG(IS_WIN)
 extern const char kAllowNoSandboxJob[];
 extern const char kAllowCrossOriginAuthPrompt[];
+extern const char kAntidetectConfig[];
 #endif

 #if BUILDFLAG(IS_CHROMEOS)
--
2.49.0
